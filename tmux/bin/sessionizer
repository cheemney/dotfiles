#!/usr/bin/env bash

BASE_DIR="$HOME/Code"

# pick project
selected=$(find "$BASE_DIR" -mindepth 1 -maxdepth 3 -type d 2>/dev/null | fzf)

[ -z "$selected" ] && exit 0

# resolve git root if exists
if git -C "$selected" rev-parse --show-toplevel >/dev/null 2>&1; then
  dir=$(git -C "$selected" rev-parse --show-toplevel)
else
  dir="$selected"
fi

# session name (clean + stable)
name=$(basename "$dir" | tr . _ | tr '[:upper:]' '[:lower:]')

# optional: avoid collisions
name=$(echo "$name" | cut -c1-30)

# create session if not exists
if ! tmux has-session -t "$name" 2>/dev/null; then
  tmux new-session -ds "$name" -c "$dir"

  # optional bootstrap window setup
  tmux rename-window -t "$name:1" "main"

  # optional: auto open nvim (comment out if not wanted)
  tmux send-keys -t "$name" "nvim" C-m
fi

# attach
tmux attach -t "$name"
