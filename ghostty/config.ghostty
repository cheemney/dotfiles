theme = light:Ayu Light,dark:Ayu

font-family = "0xProto Nerd Font"
font-size = 14

mouse-hide-while-typing = true
copy-on-select = clipboard
cursor-style-blink = true
cursor-style = block
adjust-cursor-thickness = 300%

# don't ask when closing
confirm-close-surface = false

window-theme = system

# don't show an overlay when resizing a window
resize-overlay = never

# always save the state of window when quitting
window-save-state = always

shell-integration = fish
window-inherit-working-directory = true

# the opacity level (opposite of transparency) of an unfocused split.
unfocused-split-opacity = 0.90
unfocused-split-fill = #A33503
split-divider-color = #FF4F00

# split navigation (vim-style)
keybind = super+h=goto_split:left
keybind = super+j=goto_split:bottom
keybind = super+k=goto_split:top
keybind = super+l=goto_split:right

# resize splits
keybind = super+right=resize_split:right,50
keybind = super+down=resize_split:down,50
keybind = super+left=resize_split:left,50
keybind = super+up=resize_split:up,50

# claude code shift+enter support
keybind = shift+enter=text:\n
